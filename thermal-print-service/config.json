{
  "name": "Thermal Print Service",
  "description": "Polls a remote API for todos and prints them on an Epson TM-T88V thermal receipt printer via USB",
  "version": "1.1.0",
  "slug": "thermal_print_service",
  "url": "https://github.com/DPangerl/pos-print-service-ha-addon",
  "arch": ["aarch64", "armv7", "armhf", "amd64", "i386"],
  "startup": "application",
  "boot": "auto",
  "init": false,
  "ingress": true,
  "ingress_port": 8099,
  "panel_icon": "mdi:printer",
  "panel_title": "Thermal Printer",
  "options": {
    "base_urls": ["https://todo.dpangerl.de"],
    "poll_interval": 10,
    "auth_token": "",
    "printer_device": "/dev/usb/lp0"
  },
  "schema": {
    "base_urls": ["str"],
    "poll_interval": "int",
    "auth_token": "str?",
    "printer_device": "str"
  },
  "devices": ["/dev/usb/lp0:/dev/usb/lp0:rwm"],
  "map": ["config:rw"]
}
